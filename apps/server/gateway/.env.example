# Database Connection
# Local: postgres://postgres:password@localhost:5432/circuit_db
# Production: Use the connection string for your external PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/circuit_db

# Application Port
PORT=3000

# Environment (development | production)
NODE_ENV=development

# Service Internal URLs (For Docker/Production)
# AUTH_SERVICE_URL=http://auth:3001
# GEO_SERVICE_URL=http://geo:3002
# SOCIAL_SERVICE_URL=http://social:3003

# External API Proxy
EXTERNAL_API_URL=https://api-qa.circuit-copilot.com
