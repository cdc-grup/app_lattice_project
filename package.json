{
  "name": "lattice-project",
  "version": "1.0.0",
  "packageManager": "npm@10.9.4",
  "private": true,
  "description": "Fullstack project with Express, Expo and PostgreSQL",
  "scripts": {
    "build": "turbo build --filter=!//",
    "dev": "turbo dev --filter=!//",
    "lint": "turbo lint --filter=!//",
    "test": "turbo test --filter=!//",
    "db:generate": "turbo run db:generate --filter=!//",
    "db:migrate": "turbo run db:migrate --filter=!//",
    "db:clean": "turbo run db:clean --filter=!//",
    "db:seed-montmelo": "turbo run db:seed-montmelo --filter=!//",
    "db:seed-pedralbes": "turbo run db:seed-pedralbes --filter=!//",
    "db:studio": "turbo run db:studio --filter=!//",
    "dev:zrok": "./apps/mobile/zrok-tunnel.sh",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "workspaces": [
    "apps/*",
    "apps/server/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "lucide-react-native": "^0.575.0",
    "prettier": "^3.8.1",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  },
  "overrides": {
    "eslint-plugin-react-hooks": "^5.2.0",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
